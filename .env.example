# =====================================================
# Application Configuration
# =====================================================
NODE_ENV=production
HOST=0.0.0.0
PORT=3001
APP_PORT=3001
NPM_CONFIG_STRICT_SSL=true

# =====================================================
# PostgreSQL Configuration
# =====================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=value_finder
DB_USER=postgres
DB_PASSWORD=change-this-db-password

# =====================================================
# JWT Configuration
# =====================================================
JWT_SECRET=change-this-jwt-secret-before-production
JWT_EXPIRES_IN=8h
