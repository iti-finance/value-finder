# Docker exposes the production application on port 3001.
# For `npm run dev`, set this to http://localhost:3002 instead.
BASE_URL=http://localhost:3001
HEALTH_PATH=/api/health

# Required only for `npm run smoke:browser`; do not commit real credentials.
ADMIN_EMAIL=
ADMIN_PASSWORD=
BRANCH_EMPLOYEE_CODE=
BRANCH_PASSWORD=

# `concurrent:50x200` defaults to 50 users x 4 requests = 200 total requests.
CONCURRENT_USERS=50
REQUESTS_PER_USER=4

# Browser workflow load: begin with 1x1, then increase cautiously.
WORKFLOW_USERS=1
WORKFLOW_ITERATIONS=1

# A known valid, read-only lookup row for the browser workflow test.
TEST_VEHICLE_MAKE=
TEST_VEHICLE_MODEL=
TEST_VEHICLE_VARIANT=
TEST_VEHICLE_YEAR=
